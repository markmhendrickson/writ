{
  "scenario_id": "provenance-005-correction-chain",
  "version": "1.0.0",
  "category": "provenance",
  "description": "A fact (child's birthday) is stated, then corrected twice. Probe asks to trace the full correction chain back to the original statement. Tests correction-chain provenance tracking.",
  "sessions": [
    {
      "session_id": 1,
      "timestamp": "2026-01-05T09:00:00Z",
      "messages": [
        { "role": "user", "content": "My daughter Emma's birthday is March 12." },
        { "role": "assistant", "content": "Noted — Emma's birthday is March 12." }
      ]
    },
    {
      "session_id": 2,
      "timestamp": "2026-01-20T14:00:00Z",
      "messages": [
        { "role": "user", "content": "Can you help me plan a surprise party for Emma?" },
        { "role": "assistant", "content": "Sure! Her birthday is March 12. What kind of party are you thinking?" }
      ]
    },
    {
      "session_id": 3,
      "timestamp": "2026-02-10T10:00:00Z",
      "messages": [
        { "role": "user", "content": "Wait, I think I told you the wrong date. Emma's birthday is March 14, not March 12." },
        { "role": "assistant", "content": "Corrected — Emma's birthday is March 14." }
      ]
    },
    {
      "session_id": 4,
      "timestamp": "2026-02-25T16:00:00Z",
      "messages": [
        { "role": "user", "content": "I just double-checked the birth certificate. It's actually March 13. Sorry for the confusion." },
        { "role": "assistant", "content": "No problem! Updated — Emma's birthday is March 13." }
      ]
    },
    {
      "session_id": 5,
      "timestamp": "2026-03-01T11:00:00Z",
      "messages": [
        { "role": "user", "content": "I've been going back and forth on Emma's birthday. Can you show me every date I've given you for it and when?" }
      ]
    },
    {
      "session_id": 6,
      "timestamp": "2026-03-05T09:00:00Z",
      "messages": [
        { "role": "user", "content": "Also, what was the very first date I originally told you?" }
      ]
    }
  ],
  "memory_events": [
    {
      "id": "emma_birthday",
      "type": "mutable",
      "value": "March 13",
      "introduced_in": 1,
      "updated_in": 4,
      "retracted_in": null,
      "should_persist": true,
      "previous_values": [
        { "value": "March 12", "as_of": "2026-01-05T09:00:00Z", "source_session": 1 },
        { "value": "March 14", "as_of": "2026-02-10T10:00:00Z", "source_session": 3 },
        { "value": "March 13", "as_of": "2026-02-25T16:00:00Z", "source_session": 4 }
      ]
    }
  ],
  "probe": {
    "session": 6,
    "prompt": "What was the very first date I originally told you for Emma's birthday?",
    "required_capabilities": ["retrieval", "provenance_tracing"],
    "should_abstain": false
  },
  "ground_truth": {
    "current_value": "March 13",
    "value_history": [
      { "value": "March 12", "as_of": "2026-01-05T09:00:00Z", "source_session": 1 },
      { "value": "March 14", "as_of": "2026-02-10T10:00:00Z", "source_session": 3, "correction_reason": "User self-correction" },
      { "value": "March 13", "as_of": "2026-02-25T16:00:00Z", "source_session": 4, "correction_reason": "User verified against birth certificate" }
    ],
    "provenance": {
      "source_session": 1,
      "source_message_index": 0,
      "agent_or_user": "user"
    },
    "eval_rubric": { "method": "multi_criterion", "criteria": ["identifies_march_12_as_original", "traces_to_session_1", "lists_full_correction_chain"] }
  },
  "failure_modes": ["provenance_loss", "correction_chain_collapse", "recency_bias"],
  "interference": [
    {
      "type": "echo_mention",
      "session_id": 2,
      "description": "Assistant repeats March 12 in party planning, not a new assertion"
    }
  ]
}
